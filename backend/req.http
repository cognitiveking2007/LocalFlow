### Create Order
POST http://localhost:5002/order-api/create
Content-Type: application/json

{
  "store":"6a2a5d4e6766c402b7c5e0fa",

  "products":[

    {
      "product":"6a2adeb46321817336413d7a",
      "quantity":2
    },

    {
      "product":"6a2adeb66321817336413d7b",
      "quantity":1
    }

  ],

  "total":220,

  "deliveryAddress":{
    "street":"Kothapet",
    "city":"Hyderabad",
    "pincode":"500035"
  },

  "paymentMethod":"COD"
}